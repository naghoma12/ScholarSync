@model EducationVM
@{
    ViewData["Title"] = "Edit Education";
}
<html dir="rtl" lang="ar">
   <style>
       body{
           text-align:right;
        margin-right: 55px
       }
   </style>
<body>
<div class="m-auto w-75  bg-white p-5">
    <h1 class="mr-100">تعديل</h1>
    @if (!string.IsNullOrEmpty(TempData["Message"] as string))
    {
        <div class="alert alert-primary mt-3 mb-2">
            @TempData["message"]
        </div>
    }
    <hr />

    <form asp-action="EditEducation" method="post" enctype="multipart/form-data">

        <partial name="PartialView/_CreateEdit" />

        <div class="form-group mt-4 text-right">
            <input type="submit" value="حفظ" class="btn btn-primary btn-lg" />
            <a asp-action="Index" class="btn btn-light btn-lg">الغاء</a>
        </div>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
</body>
</html>