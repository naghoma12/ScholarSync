@model IEnumerable<SimpleDept>
@{
    ViewData["Title"] = "GetAllDept";
}

<section class="ftco-section">
    <div class="container">
        
                <div class="row justify-content-center">
                    @if (Model.Any())
                    {
                        @foreach (var department in Model)
                        {

                            <div class="col-md-3 col-lg-2">
                        <a asp-controller="Scholarship" asp-action="viewschinDept" asp-route-DeptId="@department.Id" class="course-category img d-flex align-items-center justify-content-center" style="background-image: url(/Uploads/department/@department.PhotoURL);">
                                    <div class="text w-100 text-center">
                                        <input asp-for="@department.Id" hidden />
                                        <h3>@department.Name</h3>
                                        @if (department.ScholarshipCount > 0)
                                        {
                                            <span>@department.ScholarshipCount منحة</span>

                                        }
                                        else
                                        {
                                            <span> 0 منحة</span>
                                        }

                                    </div>
                                </a>
                            </div>
                        }

                    }
            </div>

            </div>
</section>