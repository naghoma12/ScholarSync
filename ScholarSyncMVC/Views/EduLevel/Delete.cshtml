@model EduLevel
@{
    ViewData["Title"] = "Delete";
}
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="m-auto w-75  p-3">
    @if (!string.IsNullOrEmpty(TempData["Message"] as string))
    {
        <div class="alert alert-primary mt-3 mb-2">
            @TempData["message"]
        </div>
    }

</div>

<h3 style="color: red">Are you sure you want to delete this?</h3>
<div>
    <form asp-action="Delete" method="post">

        <div class="col-md-4 mb-3">
            <label asp-for="Id"></label>
            <input type="text" class="form-control" asp-for="Id" readonly>

        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Name"></label>
            <input type="text" class="form-control" asp-for="Name" readonly>

        </div>
        <div class="form-group mt-4">
            <input type="submit" value="Delete" class="btn btn-danger " />
            <a asp-action="Index" class="btn btn-light">Back</a>
        </div>


    </form>

</div>



